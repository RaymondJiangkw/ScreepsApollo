{
    "compilerOptions": {
        "target": "es2017",
        "ignoreDeprecations": "6.0", 
        "moduleResolution": "node", 
        "outDir": "dist/",
        "baseUrl": "./",
        "sourceMap": true,
        "allowSyntheticDefaultImports": true,
        "allowUmdGlobalAccess": true, 
        "types": ["screeps", "lodash"], 
        "strictNullChecks": false,
        "noImplicitAny": false,
        "paths": {
            "@/*": ["./src/*"],
            "@apollo/*": ["./src/framework/*"], 
            "@test/*": ["./test/*"]
        }
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "./src/", 
        "./test/"
    ]
}